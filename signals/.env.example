# ── signals package environment variables ──────────────────────────────
# Copy this to .env and fill in your keys.

# NewsAPI.org key (get free key at https://newsapi.org/register)
NEWS_API_KEY=your_newsapi_key_here

# Anthropic Claude API key (for the LLM triage agent)
ANTHROPIC_API_KEY=your_anthropic_key_here

# How often to run the autonomous scan (in minutes)
# 60 = hourly, 1440 = daily, 10080 = weekly
SCAN_INTERVAL_MINUTES=60

# URL of the core/ orchestrator API (where confirmed signals are sent)
# Leave as default if running locally
CORE_API_URL=http://localhost:8000/signals/ingest
